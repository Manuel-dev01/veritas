# Base URL of the Veritas Go gateway ("veritas serve"). The frontend talks ONLY to this.
# Local dev: the gateway on the same machine.
NEXT_PUBLIC_GATEWAY=http://localhost:8080
# For a public deploy, point this at an HTTPS tunnel to the gateway (e.g. a cloudflared/ngrok URL),
# then rebuild/redeploy — it is baked at build time.
